---
import { getEntry, render } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { PAGES } from '../config'
import { Image } from 'astro:assets'
import GlobeD3topo from '../components/custom/GlobeD3topo.astro'
import CircleText from '../components/custom/CircleText.astro'
import bike from '../assets/png/bike.png'
import dragon from '../assets/png/dragon.png'
import latte from '../assets/png/latte.png'
import computer from '../assets/png/computer.png'

// Load bio content
const bioEntry = await getEntry('bio', 'bio')
const { Content: BioContent } = bioEntry
  ? await render(bioEntry)
  : { Content: null }
---

<BaseLayout title={PAGES.home.title}>
  {
    (PAGES.home.title || PAGES.home.subtitle) && (
      <header class="page-header">
        {PAGES.home.title && <h1 class="page-title">{PAGES.home.title}</h1>}
        {PAGES.home.subtitle && (
          <p class="page-subtitle">{PAGES.home.subtitle}</p>
        )}
      </header>
    )
  }
  <div class="container-narrow">
    <div class="prose">
      {BioContent ? <BioContent /> : <p>Loading bio...</p>}
    </div>
    <div style="display: flex; flex-direction: column; align-items: center;">
      <div class="box" id="a-globe-made-with-love">
        <div style="padding-bottom: 1em;">
          <GlobeD3topo />
        </div>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>
      <span class="body-sm inline-block"
        >A globe made with love, <a
          href="https://observablehq.com/@d3/versor-dragging"
          target="_blank"
          rel="noopener noreferrer"
          class="link">D3.JS</a
        >, and a <a
          href="https://www.jasondavies.com/maps/rotate/"
          target="_blank"
          rel="noopener noreferrer"
          class="link">lot of math</a
        >
      </span>
    </div>
    <div class="prose">
      <h2>My Life</h2>
      <p>
        I grew up in the suburbs outside of Chicago, Illinois, USA where I grew
        up as a big nerd who loved school and who also loved cycling around the
        local parks. I got my first degree at the University of Illinois at
        Urbana-Champaign in Civil and Environmental Engineering. Through my work
        as a civil engineer, I found I was drawn towards any project that let me
        explore GIS software... so I followed that interest with a masters
        degree in GIS, from the University of Wisconsin at Madison. Since then,
        I've greatly enjoyed learning web development, particularly for
        interactive mapping applications.
      </p>
      <h2>About Me</h2>
      <p>
        Outside of work I enjoy cycling, hiking, camping, (indoor) rock
        climbing, and when it's too hot to go outside I love cross stitch +
        fantasy podcasts, video games, and reading up on CSS and webdev.
      </p>

      <div class="about-png-section mt-3">
        <div class="about-png">
          <Image src={bike} alt="a bicycle icon" />
          <CircleText
            text="cycling and the outdoors"
            offset="1"
            inside={true}
          />
        </div>
        <div class="about-png">
          <Image src={dragon} alt="a styled dragon icon" />
          <CircleText text="rpgs and games" offset="25" inside={false} />
        </div>
        <div class="about-png">
          <Image src={latte} alt="a styled coffee icon with latte art" />
          <CircleText text="good food and drink" offset="15" inside={false} />
        </div>
        <div class="about-png">
          <Image src={computer} alt="an illustrated computer from the 90s" />
          <CircleText text="webdev and CSS" offset="20" inside={true} />
        </div>
      </div>

      <div class="body divider-solid my-10"></div>
      <em class="body"
        >"You cannot get through a single day without having an impact on the
        world around you. What you do makes a difference, and you have to decide
        what kind of difference you want to make." - Jane Goodall</em
      >
    </div>
  </div>
</BaseLayout>
