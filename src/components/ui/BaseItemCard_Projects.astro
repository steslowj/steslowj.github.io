---
import Tag from './Tag.astro'
import Icon from './Icon.astro'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface Props {
  title: string
  href: string
  description?: string
  date?: string
  authors?: string
  extraInput?: string
  tags?: string[]
  externalUrl?: string
  img?: string
  img_alt?: string
}

const {
  title,
  href,
  description,
  date,
  authors,
  extraInput,
  tags,
  externalUrl,
  img,
  img_alt,
} = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/preview/*.{jpeg,jpg,png,gif}'
)
if (!images[img])
  throw new Error(
    `"${img}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif}"`
  )

const shortFile = img.slice(20, -4)
---

<!-- https://uiverse.io/Smit-Prajapati/great-bat-98 cool card-->
<article class="card">
  <a href={href} class="card-title">{title}</a>

  <div
    class="card-content border-border flex flex-col flex-wrap items-center gap-2 border-t p-2 pb-4 md:flex-row md:items-start">
    <div class="border-accent flex-none">
      <a href={href} class="card-img-link rounded-sm">
        <Image
          src={images[img]()}
          alt={img_alt}
          width="400"
          height="auto"
          class="card-img rounded-sm border p-1"
        />
      </a>
    </div>

    <div class="flex flex-1 flex-col gap-2 px-4 md:px-0">
      {img && description && <p class="card-desc-projects">{description}</p>}
      {
        tags && tags.length > 0 && (
          <div class="mb-3 flex flex-wrap gap-2 md:flex-col">
            {tags.map((tag) => (
              <Tag name={tag} size="sm" />
            ))}
          </div>
        )
      }
    </div>
  </div>

  {
    externalUrl && (
      <div class="shrink-0">
        <a
          href={externalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="card-link">
          <span class="flex items-center gap-1">
            <span>View live site</span>
            <Icon name="ExternalLink" size={24} />
          </span>
        </a>
      </div>
    )
  }
</article>
